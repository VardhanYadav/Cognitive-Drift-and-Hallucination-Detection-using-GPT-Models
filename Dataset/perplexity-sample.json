    "topic": "Explaining Quantum Computing",
    "turns": [
      {"role": "user", "message": "Explain quantum computing simply."},
      {"role": "assistant", "message": "Classical bits: 0 or 1. Qubits: superposition, both until measured. Like spinning coin heads/tails till it lands."},
      {"role": "user", "message": "Entanglement?"},
      {"role": "assistant", "message": "Linked qubits: Measure one, instant effect on other, even miles apart. Einstein's 'spooky action'."},
      {"role": "user", "message": "Why faster?"},
      {"role": "assistant", "message": "Parallel universes vibe: Tries all paths at once for factoring, search."},
      {"role": "user", "message": "Real world use?"},
      {"role": "assistant", "message": "Drug discovery (molecule sims), optimization (logistics). IBM, Google building now."},
      {"role": "user", "message": "Risks?"},
      {"role": "assistant", "message": "Breaks encryption; post-quantum crypto needed."}
    ]
